{
  "name": "guitar-pro-clone-webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "node scripts/build.mjs",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test --project=chromium",
    "test:visual": "playwright test --project=visual-1024x768 --project=visual-1280x768 --project=visual-1440x900 --project=visual-1920x1080",
    "test:visual:update": "playwright test --project=visual-1024x768 --project=visual-1280x768 --project=visual-1440x900 --project=visual-1920x1080 --update-snapshots"
  },
  "dependencies": {
    "immer": "^10.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "terser": "^5.49.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
